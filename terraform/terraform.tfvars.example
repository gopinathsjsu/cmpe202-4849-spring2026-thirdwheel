# Copy to terraform.tfvars (gitignored) and fill in.
# Do NOT commit secrets.

project_id  = "zestify-cmpe202"
region      = "us-west1"

# Container images (after build + push to Artifact Registry)
backend_image  = "us-west1-docker.pkg.dev/zestify-cmpe202/zestify/backend:latest"
frontend_image = "us-west1-docker.pkg.dev/zestify-cmpe202/zestify/frontend:latest"

# GCS bucket for uploads (must be globally unique)
uploads_bucket_name = "zestify-uploads-cmpe202"

# Secrets (use TF_VAR_* env vars in CI rather than committing here)
jwt_secret             = "change-me"
db_password            = "change-me"
stripe_secret_key      = "sk_test_xxx"
stripe_publishable_key = "pk_test_xxx"
