{
  "name": "zestify-backend",
  "version": "2.0.0",
  "description": "Zestify Event Platform - Backend API (Postgres + scalable patterns)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node db/seed.js",
    "migrate": "node -e \"require('./db/pool').migrate().then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "test": "node --test 'tests/unit/*.test.js'",
    "test:unit": "node --test 'tests/unit/*.test.js'",
    "test:integration": "node --test 'tests/integration/*.test.js'"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.13.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "redis": "^4.7.0",
    "uuid": "^11.0.3"
  }
}
